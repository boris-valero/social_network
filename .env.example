# 🔐 Configuration Environnement - Template
# ============================================
# IMPORTANT: 
# 1. Copier ce fichier en .env
#    cp .env.example .env
# 2. Modifier les valeurs CHANGEZ-MOI
# 3. Ne JAMAIS commiter .env (secrets réels)
#
# Générer des mots de passe forts:
# openssl rand -base64 32

# ===== BASE DE DONNÉES =====
DB_HOST=db
DB_USER=socialnetwork_user
DB_PASS=CHANGEZ-MOI-MOT-DE-PASSE-FORT
DB_NAME=socialnetwork
DB_ROOT_PASSWORD=CHANGEZ-MOI-MOT-DE-PASSE-ROOT

# ===== CONFIGURATION PHP =====
PHP_MEMORY_LIMIT=256M
PHP_MAX_UPLOAD_SIZE=50M

# ===== PRODUCTION (optional) =====
# APP_ENV=production
# APP_DEBUG=false
